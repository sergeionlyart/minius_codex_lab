history.jsonl

# Prohibited/local data classifications
restricted/
personal-data/
personal_data/
state-secret/
state_secret/
vault/
dsk/

# Runtime data accidentally created at the public repository root
/matters/*
!/matters/_template/
!/matters/_template/**
/memory/
/logs/
/artifacts/
/outputs/
/exports/

# Keep only the sanitized matter template inside the release source
/workspace-template/matters/*
!/workspace-template/matters/AGENTS.md
!/workspace-template/matters/README.md
!/workspace-template/matters/_template/
!/workspace-template/matters/_template/**

# Runtime-generated state inside workspace-template is local only
/workspace-template/memory/sessions/*
!/workspace-template/memory/sessions/.gitkeep
/workspace-template/logs/raw/*
!/workspace-template/logs/raw/.gitkeep
!/workspace-template/logs/raw/README.md
/workspace-template/logs/curated/*
!/workspace-template/logs/curated/.gitkeep
!/workspace-template/logs/curated/README.md
/workspace-template/artifacts/*
!/workspace-template/artifacts/.gitkeep
!/workspace-template/artifacts/README.md

# Python, test, and tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/

# Temporary/generated files
.tmp/
tmp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*.orig
*.rej
*.log

