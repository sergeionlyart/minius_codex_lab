/CODEX_SETUP_PROMPT_RU.md
/minjust_codex_legal_workspace_v1.0.0.zip

# Generated distribution artifacts
/dist/
/build/
*.zip
*.zip.sha256
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Secrets, credentials, keys, and local configuration
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.kdbx
credentials*.json
secrets*.json
auth.json
.codex/auth.json
.codex/local/
.codex/logs/
.codex/tmp/
.codex/sessions/
